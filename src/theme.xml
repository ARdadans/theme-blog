<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:css='false'
      b:defaultmessages='true'
      b:defaultwidgetversion='2'
      b:layoutsVersion='3'
      b:responsive='true'
      b:templateVersion='1.0.0'
      expr:dir='data:blog.languageDirection'
      expr:lang='data:blog.locale.language'
      lang='en'
      xmlns='http://www.w3.org/1999/xhtml'
      xmlns:b='http://www.google.com/2005/gml/b'
      xmlns:data='http://www.google.com/2005/gml/data'
      xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
  <meta charset='UTF-8'/>
  <meta content='width=device-width, initial-scale=1' name='viewport'/>

  <title>
    <b:if cond='data:view.isHomepage'>
      <data:blog.title/> - Latest Manga Updates
    <b:else/>
      <data:blog.pageName/> - <data:blog.title/>
    </b:if>
  </title>

  <src:include src="includes/seo-meta.xml" />
  <src:include src="includes/fonts-icons.xml" />

  <b:skin><![CDATA[
  /* [CSS_INJECT] */
  ]]></b:skin>

  <b:if cond='data:view.isPost and data:post.labels any (l =&gt; l.name == &quot;type:series&quot; or l.name == &quot;type: series&quot; or l.name == &quot;Series&quot; or l.name == &quot;Type:Series&quot;)'>
    <style>
      <src:include src="css/series-page.css" />
    </style>
  </b:if>

  <b:if cond='data:view.isLayoutMode'>
    <b:template-skin><![CDATA[
      body#layout:before{content:'MangaPro Theme';position:absolute;top:15px;right:15px;font-size:.8rem;font-family:sans-serif;color:rgba(0,0,0,0.5)}
      body#layout{width:1025px;margin:0 !important;padding:60px 0 0 !important;position:relative}
      body#layout .Blog .widget-content{height:auto!important}
      body#layout div.section{border:1px dashed #ccc;border-radius:4px;padding:15px;}
    ]]></b:template-skin>
  </b:if>
</head>

<body>
  <b:attr name='id' value='mainContent'/>
  <b:class cond='data:view.url == data:view.url params { amp: &quot;1&quot; }' name='nAmp'/>
  <b:class cond='data:blog.languageDirection == &quot;rtl&quot;' name='nRtl'/>
  <b:class cond='data:view.isMultipleItems' name='onIndx'/>
  <b:class cond='data:view.isHomepage' name='onBlg'/>
  <b:class cond='data:view.isSingleItem' name='onItm'/>
  <b:class cond='data:view.isPage' name='onPg'/>
  <b:class cond='data:view.isPost' name='onPst'/>
  <b:class cond='data:view.isError' name='on404'/>

  <b:tag class='mainWrp' cond='!data:view.isError' name='div'>
    <src:include src="components/component-header.xml" />

    <div class='max-w-theme mx-auto px-5 md:px-8 lg:px-12 w-full mt-5 mb-12 block'>
      <src:include src="components/component-announcement.xml" />
      <src:include src="components/component-bookmarks.xml" />

      <div class='grid grid-cols-1 lg:grid-cols-10 gap-6 lg:gap-8 items-start'>
        <div expr:class='data:view.isHomepage ? "lg:col-span-7" : "lg:col-span-10"'>
          <src:include src="sections/section-main.xml" />
        </div>

        <b:if cond='data:view.isHomepage'>
          <aside class='lg:col-span-3'>
            <src:include src="sections/section-popular-series.xml" />
          </aside>
        </b:if>
      </div>
    </div>

    <src:include src="components/component-footer.xml" />
  </b:tag>

  <b:if cond='data:view.isError'>
    <section class='erroP'>
      <div class='error-view-box'>
        <h1>404</h1>
        <p>The page you requested could not be located on the server.</p>
        <a class='btn-back-home' expr:href='data:blog.homepageUrl.canonical'>Take Me Back Home</a>
      </div>
    </section>
  <b:elseif cond='data:view.isLayoutMode'/>
    <section class='erroP'>
      <div class='error-view-box'>
        <h1>Layout Preview</h1>
        <p>This preview is only visible while the Blogger layout editor is active.</p>
      </div>
    </section>
  </b:if>

  <script type='text/javascript'>
    //<![CDATA[
    /* [GLOBAL_JS_INJECT] */
    //]]>
  </script>
</body>
</html>
