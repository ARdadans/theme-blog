<b:section id='popular-section' name='Popular Series' maxwidgets='1' showaddelement='yes'>
  <b:widget id='PopularPosts1' locked='false' title='Popular Series' type='PopularPosts' version='2' visible='true'>
    <b:includable id='main'>
      <div class='bg-surface rounded-theme p-4 border border-border'>
        <h2 class='text-sm font-bold capitalize tracking-[0.5px] mb-4 text-text'><data:title/></h2>
        <div class='flex flex-col gap-3' id='popular-section-list' style='counter-reset: popular-rank;'>
          <b:loop values='data:posts' var='post' index='i'>
            <b:if cond='data:post.labels any (l =&gt; l.name == &quot;type:series&quot; or l.name == &quot;type: series&quot; or l.name == &quot;Series&quot; or l.name == &quot;Type:Series&quot;)'>
              <div class='group flex gap-3 items-center bg-card p-2 rounded-theme border border-border transition-normal'>
                <!-- Compact Cover Image (2:3 Aspect Ratio) -->
                <a class='w-12 aspect-[2/3] rounded overflow-hidden flex-shrink-0 bg-surface block' expr:href='data:post.url'>
                  <b:if cond='data:post.featuredImage'>
                    <img class='w-full h-full object-cover transition-normal' expr:alt='data:post.title' expr:src='data:post.featuredImage' loading='lazy'/>
                  <b:elseif cond='data:post.thumbnailUrl'/>
                    <img class='w-full h-full object-cover transition-normal' expr:alt='data:post.title' expr:src='data:post.thumbnailUrl' loading='lazy'/>
                  <b:else/>
                    <div class='flex items-center justify-center text-[9px] font-bold text-muted bg-surface h-full w-full'>Series</div>
                  </b:if>
                </a>
                
                <!-- Content -->
                <div class='flex flex-col gap-1 flex-grow min-w-0'>
                  <h4 class='text-xs font-semibold leading-snug line-clamp-2 group-hover:text-primary transition-fast'>
                    <a expr:href='data:post.url'><data:post.title/></a>
                  </h4>
                  <div class='flex items-center gap-2 mt-0.5'>
                    <span class='text-[9px] font-black text-muted bg-surface px-1.5 py-0.5 rounded border border-border popular-rank'></span>
                  </div>
                </div>
              </div>
            </b:if>
          </b:loop>
        </div>
      </div>
    </b:includable>
  </b:widget>
</b:section>
