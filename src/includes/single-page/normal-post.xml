<b:includable id='normalPost' var='post'>
  <article class='bg-card rounded-theme p-5 md:p-[30px] shadow-card border border-border mb-[30px]'>
    
    <!-- Post Title -->
    <h1 class='text-2xl md:text-[28px] font-extrabold mb-[15px] leading-tight text-text'><data:post.title/></h1>

    <!-- Post Meta Info -->
    <div class='flex flex-col gap-2.5 border-b border-border pb-[15px] mb-5 text-xs md:text-[13px] text-muted'>
      <div class='flex flex-wrap gap-2.5 md:gap-5'>
        <div>
          <span class='font-semibold mr-[5px] text-text-soft'>Published:</span>
          <span><data:post.date.escaped/></span>
        </div>
        <div>
          <span class='font-semibold mr-[5px] text-text-soft'>Author:</span>
          <span><data:post.author.name/></span>
        </div>
      </div>
      
      <!-- Post Labels / Tags list -->
      <b:if cond='data:post.labels'>
        <div class='flex flex-wrap gap-1.5 mt-0.5'>
          <b:loop values='data:post.labels' var='label'>
            <a class='bg-surface border border-border text-muted text-[10px] font-semibold px-2 py-0.5 rounded hover:text-primary hover:border-transparent hover:bg-primary/10 transition-fast font-sans' expr:href='data:label.url'>
              <data:label.name/>
            </a>
          </b:loop>
        </div>
      </b:if>
    </div>

    <!-- Main Content Body -->
    <div class='post-body series-post-body details-mode' id='post-body'>
      <data:post.body/>
    </div>

    <!-- Discussion Comments Area -->
    <div class='mt-10 border-t border-border pt-[30px]'>
      <b:include name='commentPicker' data='post'/>
    </div>

  </article>
</b:includable>
